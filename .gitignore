# OS
.DS_Store
**/.DS_Store

# Originales pesados (HEIC/JPG fuente) — se mantienen LOCALMENTE, no en el repo
images/

# Dependencias de build (Tailwind CLI). El CSS compilado (dist/) SÍ se versiona.
node_modules/

# Modelos 3D no usados por el sitio (solo se publican cojin3.glb y cojin4.glb).
# Se mantienen LOCALMENTE; no se suben al repo ni a producción.
assets/3d/cojin.glb
assets/3d/cojin2.glb
assets/3d/cojines.glb
assets/3d/cojines2.glb
# Backups de los GLB sin comprimir (antes de Draco) — solo locales
assets/3d/*.orig.glb

# Texturas de tela: originales pesados fuera del repo; se publican los JPG optimizados (tela-*.jpg)
assets/telas/*.png
# Catálogo de telas: originales sin optimizar fuera del repo; se publican los tela-NN.jpg
assets/telas/web/*.png
assets/telas/web/[0-9].jpg
assets/telas/web/[0-9][0-9].jpg

# Borradores y temporales
*.log
_test*.html
_mv*.html
_sv*.html
